{
  "env": {
    "browser": true,
    "webextensions": true,
    "es2021": true,
    "jest/globals": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:jest/recommended"
  ],
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^(initChat|llmSummarizeLong|llmExtractEntities|llmQuiz|llmChat|markdownToHtml|setSafeHTML|handleGenerateQuiz|renderSummaryCard|fetchTranscriptInPageContext|getProcessedTranscript|CATEGORY_LABELS|formatDuration)$" }],
    "no-empty": "warn",
    "no-undef": "error"
  },
  "globals": {
    "browser": "readonly",
    "setSafeHTML": "readonly",
    "markdownToHtml": "readonly",
    "llmChat": "readonly",
    "llmSummarizeLong": "readonly",
    "llmExtractEntities": "readonly",
    "llmQuiz": "readonly",
    "localizePage": "readonly",
    "getLocalizedString": "readonly",
    "getProcessedTranscript": "readonly",
    "initChat": "readonly",
    "handleGenerateQuiz": "readonly",
    "fetchTranscriptInPageContext": "readonly",
    "I18N": "readonly",
    "buildSystemInstruction": "readonly",
    "chunkTranscript": "readonly",
    "DETAIL_PROMPTS": "readonly",
    "PERSONA_PROMPTS": "readonly",
    "resolvePersona": "readonly",
    "renderSummaryCard": "readonly",
    "CATEGORY_LABELS": "readonly",
    "formatDuration": "readonly"
  },
  "ignorePatterns": [
    "node_modules/",
    "tests/"
  ]
}